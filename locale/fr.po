msgid ""
"Select a project folder with translatable source code.\n"
"\n"
"Scans for translatable strings using gettext patterns\n"
"and generates .po files for each target language.\n"
"\n"
"Supported project types:\n"
"Python, C/C++, JavaScript, Shell, Vala\n"
"and any project using gettext"
msgstr ""
"Sélectionnez un dossier de projet contenant du code source traduisible.\n"
"\n"
"Analyse les chaînes traduisibles en utilisant des motifs gettext\n"
"et génère des fichiers .po pour chaque langue cible.\n"
"\n"
"Types de projets pris en charge :\n"
"Python, C/C++, JavaScript, Shell, Vala\n"
"et tout projet utilisant gettext"
# 
# File: usr/share/langforge/utils/tooltip_helper.py, line: 36
#: NEEDS WORK
msgid ""
"Select a single file to translate directly.\n"
"\n"
"Supported formats:\n"
".po / .pot — Gettext translation files\n"
".json — Key-value translation files\n"
".srt — SubRip subtitle files\n"
".txt / .md — Plain text and Markdown"
msgstr ""
"Sélectionnez un seul fichier à traduire directement.\n"
"\n"
"Formats pris en charge :\n"
".po / .pot — Fichiers de traduction Gettext\n"
".json — Fichiers de traduction clé-valeur\n"
".srt — Fichiers de sous-titres SubRip\n"
".txt / .md — Texte brut et Markdown"
