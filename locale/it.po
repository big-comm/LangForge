msgid ""
"Select a project folder with translatable source code.\n"
"\n"
"Scans for translatable strings using gettext patterns\n"
"and generates .po files for each target language.\n"
"\n"
"Supported project types:\n"
"Python, C/C++, JavaScript, Shell, Vala\n"
"and any project using gettext"
msgstr ""
"Seleziona una cartella di progetto con codice sorgente traducibile.\n"
"\n"
"Scansiona le stringhe traducibili utilizzando i modelli gettext\n"
"e genera file .po per ogni lingua target.\n"
"\n"
"Tipi di progetto supportati:\n"
"Python, C/C++, JavaScript, Shell, Vala\n"
"e qualsiasi progetto che utilizza gettext"
# 
# File: usr/share/langforge/utils/tooltip_helper.py, line: 36
#: NEEDS WORK
msgid ""
"Select a single file to translate directly.\n"
"\n"
"Supported formats:\n"
".po / .pot — Gettext translation files\n"
".json — Key-value translation files\n"
".srt — SubRip subtitle files\n"
".txt / .md — Plain text and Markdown"
msgstr ""
"Seleziona un singolo file da tradurre direttamente.\n"
"\n"
"Formati supportati:\n"
".po / .pot — File di traduzione Gettext\n"
".json — File di traduzione chiave-valore\n"
".srt — File di sottotitoli SubRip\n"
".txt / .md — Testo semplice e Markdown"
