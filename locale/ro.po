msgid ""
"Select a single file to translate directly.\n"
"\n"
"Supported formats:\n"
".po / .pot — Gettext translation files\n"
".json — Key-value translation files\n"
".srt — SubRip subtitle files\n"
".txt / .md — Plain text and Markdown"
msgstr ""
"Selectați un singur fișier pentru a traduce direct.\n"
"\n"
"Formate acceptate:\n"
".po / .pot — Fișiere de traducere Gettext\n"
".json — Fișiere de traducere cheie-valoare\n"
".srt — Fișiere de subtitrări SubRip\n"
".txt / .md — Text simplu și Markdown"
