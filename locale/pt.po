msgid ""
"Select a single file to translate directly.\n"
"\n"
"Supported formats:\n"
".po / .pot — Gettext translation files\n"
".json — Key-value translation files\n"
".srt — SubRip subtitle files\n"
".txt / .md — Plain text and Markdown"
msgstr ""
"Selecione um único arquivo para traduzir diretamente.\n"
"\n"
"Formatos suportados:\n"
".po / .pot — Arquivos de tradução Gettext\n"
".json — Arquivos de tradução chave-valor\n"
".srt — Arquivos de legenda SubRip\n"
".txt / .md — Texto simples e Markdown"
